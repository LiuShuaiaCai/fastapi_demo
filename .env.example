# Database
DATABASE_URL=sqlite:///./test.db

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
DEBUG=True
APP_NAME=FastAPI Demo
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# CORS
CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
